{
    "name": "@krutai/auth",
    "version": "0.1.9",
    "description": "Authentication package for KrutAI — installs krutai, better-auth, and better-sqlite3 automatically",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./react": {
            "types": "./dist/react.d.ts",
            "import": "./dist/react.mjs",
            "require": "./dist/react.js"
        },
        "./next-js": {
            "types": "./dist/next-js.d.ts",
            "import": "./dist/next-js.mjs",
            "require": "./dist/next-js.js"
        }
    },
    "files": [
        "dist",
        "scripts",
        "README.md",
        "AI_REFERENCE.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "clean": "rm -rf dist *.tsbuildinfo",
        "typecheck": "tsc --noEmit",
        "postinstall": "node scripts/migrate.js"
    },
    "keywords": [
        "krutai",
        "auth",
        "authentication",
        "better-auth"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "better-auth": "^1.1.7",
        "better-sqlite3": "^12.0.0",
        "@types/better-sqlite3": "^7.6.0",
        "krutai": "^0.1.2"
    },
    "peerDependencies": {
        "krutai": ">=0.1.2"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "tsup": "^8.0.1",
        "typescript": "^5.3.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AccountantAIOrg/krut_packages.git",
        "directory": "packages/auth"
    }
}