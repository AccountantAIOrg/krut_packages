{
    "name": "@krutai/rbac",
    "version": "0.1.1",
    "description": "Role-Based Access Control (RBAC) library for KrutAI",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "AI_REFERENCE.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "clean": "rm -rf dist *.tsbuildinfo",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "krutai",
        "rbac",
        "role-based-access-control",
        "authorization",
        "permissions",
        "roles"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^20.11.0",
        "krutai": "^0.1.2",
        "tsup": "^8.0.1",
        "typescript": "^5.3.3"
    },
    "peerDependencies": {
        "krutai": ">=0.1.2",
        "@krutai/auth": ">=0.1.0"
    },
    "peerDependenciesMeta": {
        "krutai": {
            "optional": false
        },
        "@krutai/auth": {
            "optional": true
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/AccountantAIOrg/krut_packages.git",
        "directory": "packages/rbac"
    }
}