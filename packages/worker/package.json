{
  "name": "@krutai/worker",
  "version": "1.0.0",
  "description": "Background worker with retry mechanism for KrutAI (powered by BullMQ)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "krutai",
    "worker",
    "queue",
    "bullmq",
    "background-jobs",
    "retry"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bullmq": "5.73.5",
    "ioredis": "5.10.1",
    "krutai": ">=0.1.5"
  },
  "peerDependencies": {
    "krutai": ">=0.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AccountantAIOrg/krut_packages.git",
    "directory": "packages/worker"
  }
}
